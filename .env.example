FUKO_DATABASE_URL=postgresql://fuko:secret@localhost:5432/fuko

# Embeddings (any OpenAI-compatible /embeddings endpoint). The vector column
# is sized to whatever the model returns (probed at startup), so FUKO_EMBED_DIM
# is only a fallback used when the probe can't run.
#   - Ollama:   base http://localhost:11434/v1, model bge-m3 (dim 1024)
#   - z.ai:     base https://api.z.ai/api/paas/v4, reuse your GLM key (verify the
#               embedding model name + dim against the live API)
#   - bigmodel: base https://open.bigmodel.cn/api/paas/v4, model embedding-3 (dim 2048)
#   - OpenAI:   base https://api.openai.com/v1, model text-embedding-3-small (dim 1536)
FUKO_EMBED_BASE_URL=http://localhost:11434/v1
FUKO_EMBED_MODEL=bge-m3
# FUKO_EMBED_API_KEY=          # set for remote providers (e.g. your GLM/z.ai key)
# FUKO_EMBED_DIM=1024          # fallback dim if the startup probe can't reach the model

# Sidecar:
# FUKO_AUTH_TOKEN=optional-shared-secret-for-write-endpoints
# FUKO_TOP_K=6
# FUKO_HOST=0.0.0.0
# FUKO_PORT=8000
